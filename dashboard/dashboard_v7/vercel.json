{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/server.ts": {
      "runtime": "@vercel/node@3",
      "maxDuration": 30,
      "includeFiles": "data/**"
    }
  }
}
