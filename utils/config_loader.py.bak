import json


def load_settings():

    with open(
        "config/settings.json",
        "r"
    ) as f:

        return json.load(f)


def load_universe():

    with open(
        "config/universe.json",
        "r"
    ) as f:

        config = json.load(f)

    universe_file = config["source"]

    with open(
        universe_file,
        "r"
    ) as f:

        return json.load(f)